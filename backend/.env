# BotDog 后端配置文件
# 此文件可以覆盖 config.py 中的默认值

# ==================== 视频流配置 ====================
# 视频流配置（覆盖 config.py 默认值）
VIDEO_RESOLUTION=1920x1080
VIDEO_BITRATE=8000000
VIDEO_FRAMERATE=60
VIDEO_UDP_PORT=19856
VIDEO_WATCHDOG_TIMEOUT_S=5.0

# ==================== WebRTC 配置 ====================
# WebRTC STUN/TURN 服务器列表
WEBRTC_ICE_SERVERS=["stun:stun.l.google.com:19302"]

# ==================== 基础网络配置 ====================
# 后端监听地址和端口
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ==================== MAVLink / 数据库 ====================
# MAVLink 端点配置
MAVLINK_ENDPOINT=udp:127.0.0.1:14550

# 数据库 URL
DATABASE_URL=sqlite+aiosqlite:///./data/botdog.db

# ==================== 安全配置 ====================
# JWT 密钥（生产环境请修改）
JWT_SECRET=please_change_me

# ==================== CORS 配置 ====================
# CORS 允许的源
CORS_ALLOW_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=false

# ==================== MAVLink 数据源选择 ====================
# 数据源选择：mavlink|simulation
# - mavlink: 使用真实 MAVLink 端口
# - simulation: 使用模拟数据生成器
MAVLINK_SOURCE=simulation

# ==================== 模拟数据 Worker 控制 ====================
# 本地模拟数据 Worker 控制（默认保持当前启用行为）
SIMULATION_WORKER_ENABLED=true

# ==================== 控制通道配置 ====================
# 控制指令限流（Hz）
CONTROL_RATE_LIMIT_HZ=20.0

# 摇杆死区（0-1000）
CONTROL_DEADZONE=50

# ==================== 心跳和遥测配置 ====================
# 心跳超时（秒）
HEARTBEAT_TIMEOUT=3.0

# 遥测落盘采样频率（Hz）
TELEMETRY_SAMPLING_HZ=2.0

# 遥测广播频率（Hz）
TELEMETRY_BROADCAST_HZ=15.0

# ==================== AI 告警配置 ====================
# 温度阈值（°C）
THERMAL_THRESHOLD=60.0
