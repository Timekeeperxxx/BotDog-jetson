# BotDog 后端配置文件
# 此文件可以覆盖 config.py 中的默认值

# ==================== 基础网络配置 ====================
# 后端监听地址和端口
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ==================== MAVLink / 数据库 ====================
# MAVLink 端点配置
MAVLINK_ENDPOINT=udp:127.0.0.1:14550

# 数据库 URL
DATABASE_URL=sqlite+aiosqlite:///./data/botdog.db

# ==================== 安全配置 ====================
# JWT 密钥（生产环境请修改）
JWT_SECRET=please_change_me

# ==================== CORS 配置 ====================
# CORS 允许的源
CORS_ALLOW_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=false

# ==================== MAVLink 数据源选择 ====================
# 数据源选择：mavlink|simulation
# - mavlink: 使用真实 MAVLink 端口
# - simulation: 使用模拟数据生成器
MAVLINK_SOURCE=simulation

# ==================== 模拟数据 Worker 控制 ====================
# 本地模拟数据 Worker 控制（默认保持当前启用行为）
SIMULATION_WORKER_ENABLED=true

# ==================== 心跳和遥测配置 ====================
# 心跳超时（秒）
HEARTBEAT_TIMEOUT=3.0

# 遥测落盘采样频率（Hz）
TELEMETRY_SAMPLING_HZ=2.0

# 遥测广播频率（Hz）
TELEMETRY_BROADCAST_HZ=15.0

# ==================== AI 告警配置 ====================
# 温度阈值（°C）
THERMAL_THRESHOLD=80.0

# ==================== 旁路 AI 识别与抓拍 ====================
AI_ENABLED=true
AI_RTSP_URL=rtsp://127.0.0.1:8554/cam
AI_FRAME_WIDTH=1920
AI_FRAME_HEIGHT=1080
AI_FPS=10
AI_PATROL_SKIP=5
AI_SUSPECT_SKIP=1
AI_STABLE_HITS=3
AI_RESET_MISSES=3
AI_COOLDOWN_SECONDS=5.0
AI_SIMULATE_DETECTION=false
AI_SIMULATE_PROB=0.02
AI_DEVICE=auto
AI_MODEL_PATH=yolov8n.pt
AI_CONFIDENCE_THRESHOLD=0.5
AI_TARGET_CLASSES=["person"]

