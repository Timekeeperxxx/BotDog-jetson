# BotDog 后端配置模板
# 复制此文件为 .env 并根据实际情况修改：
#   cp backend/.env.example backend/.env

# ==================== 基础网络 ====================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ==================== 数据库 & MAVLink ====================
DATABASE_URL=sqlite+aiosqlite:///./data/botdog.db
# 真实硬件示例：serial:/dev/ttyUSB0:57600
MAVLINK_ENDPOINT=udp:127.0.0.1:14550
# mavlink=真实硬件 | simulation=纯模拟
MAVLINK_SOURCE=simulation
# MAVLINK_SOURCE=simulation 时设为 true 以生成随机遥测数据
SIMULATION_WORKER_ENABLED=true

# ==================== 安全 ====================
# 生产环境请务必修改为随机字符串
JWT_SECRET=please_change_me_to_a_random_string

# ==================== CORS ====================
# 生产环境改为前端实际 IP，如 ["http://192.168.110.247:5173"]
CORS_ALLOW_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=false

# ==================== 遥测 ====================
HEARTBEAT_TIMEOUT=3.0
TELEMETRY_SAMPLING_HZ=2.0
TELEMETRY_BROADCAST_HZ=15.0

# ==================== 告警 ====================
THERMAL_THRESHOLD=80.0

# ==================== AI 识别 ====================
# 需要 yolov8n.pt 模型（~6MB），下载：
# https://github.com/ultralytics/assets/releases/download/v8.2.0/yolov8n.pt
AI_ENABLED=false
# AI Worker 从 MediaMTX 拉取推理帧
AI_RTSP_URL=rtsp://127.0.0.1:8554/cam
AI_FRAME_WIDTH=1280
AI_FRAME_HEIGHT=720

# 推理帧率：越高 ByteTrack 跨帧 IOU 越稳，但 CPU 占用也越高
AI_FPS=15

# 巡逻跳帧：每隔多少帧推理一次（1=不跳帧，建议 1~3）
# 过大会导致摄像头抖动时相邻帧位移过大，ByteTrack 断轨丢目标
AI_PATROL_SKIP=1

# 发现疑似目标后切全速推理，保持 1 即可
AI_SUSPECT_SKIP=1

# 锁定目标需要连续命中几帧（值越小锁定越快，但误报也增加）
AI_STABLE_HITS=2

# 连续几帧未检测到才放弃目标（值越大对遮挡/抖动越宽容）
AI_RESET_MISSES=8

# 同一目标停止告警后，多少秒内不重复告警
AI_COOLDOWN_SECONDS=5.0

# 推理设备：auto 自动选 cuda/cpu | cpu | cuda
AI_DEVICE=auto
AI_MODEL_PATH=models/yolov8n.pt

# 置信度阈值：越低检出率越高但误报变多，运动模糊场景建议 0.3~0.4
AI_CONFIDENCE_THRESHOLD=0.35
AI_TARGET_CLASSES=["person"]

# 抓拍图片存储目录（相对于项目根）
SNAPSHOT_DIR=data/snapshots

# ==================== 导航巡逻 / PCD 点云地图 Demo ====================
# 同事建好的 PCD 点云地图所在目录。Demo 阶段不上传、不拷贝，后端直接扫描该目录。
PCD_MAP_ROOT=/home/jetson/maps

# 当前点云和导航点默认使用的坐标系
PCD_FRAME_ID=map

# 点云预览默认返回点数
PCD_PREVIEW_DEFAULT_POINTS=100000

# 点云预览最大允许返回点数，防止浏览器卡死
PCD_PREVIEW_MAX_POINTS=200000

# Demo 阶段导航点 JSON 存储目录
NAV_WAYPOINT_STORE_DIR=./data/nav_waypoints

# ==================== ROS2 导航状态订阅转发 ====================
# 是否启用后端 ROS2 导航位姿转发。未安装 ROS2/rclpy/tf2_ros 时后端会跳过并继续提供其他接口。
ROS_NAV_ENABLED=true

# 位姿 topic 模式使用的 ROS2 topic；ROS_NAV_POSE_TYPE=TF 时不使用。
ROS_NAV_POSE_TOPIC=/amcl_pose

# 位姿来源类型。推荐 TF：后端查询 ROS_NAV_FRAME_ID -> ROS_NAV_BASE_FRAME_ID 的坐标变换。
# 也支持：PoseWithCovarianceStamped / PoseStamped / Odometry。
ROS_NAV_POSE_TYPE=TF

# TF 查询目标坐标系，也是前端 PCD Demo 使用的地图坐标系。
ROS_NAV_FRAME_ID=map

# TF 查询源坐标系，通常是机器人本体坐标系 base_link。
ROS_NAV_BASE_FRAME_ID=base_link

# WebSocket 转发 robot_pose 的最大频率
ROS_NAV_BROADCAST_HZ=10

# 调试用模拟检测，无需模型文件，正式部署必须关闭
AI_SIMULATE_DETECTION=false
AI_SIMULATE_PROB=0.02

# ==================== 控制服务 ====================
# simulation=仅打印日志 | unitree_b2=宇树 B2 真实硬件
CONTROL_ADAPTER_TYPE=simulation

# 前端超过此时间未发命令，后端自动执行 stop（真实硬件 RPC 延迟大，建议 1500ms）
CONTROL_WATCHDOG_TIMEOUT_MS=500

# 前端命令最小发送间隔（ms），stop 命令不受此限制
CONTROL_CMD_RATE_LIMIT_MS=50

# ==================== 自动跟踪 ====================
AUTO_TRACK_ENABLED=true

# 追踪服务向控制服务发命令的最小间隔（ms）
AUTO_TRACK_COMMAND_INTERVAL_MS=100

AUTO_TRACK_TARGET_HOLD_SECONDS=3.0

# 目标连续出追踪区域几帧后停止（@15fps: 10帧≈0.7s）
AUTO_TRACK_OUT_OF_ZONE_FRAMES=10

# 目标丢失几帧后回到 DETECTING 重新扫描（@15fps: 30帧≈2s）
AUTO_TRACK_LOST_TIMEOUT_FRAMES=30

# 画面中心±N 像素内不发转向命令，防止频繁左右抖动
AUTO_TRACK_YAW_DEADBAND_PX=40

# 目标 bbox 面积超过画面面积的此比例时停止前进（0.35≈目标充满约60%画宽）
AUTO_TRACK_FORWARD_AREA_RATIO=0.35

# 目标底部锚点超过画面高度此比例时禁止前进，防近距离前冲
AUTO_TRACK_ANCHOR_Y_STOP_RATIO=0.88

# 跟踪结束时是否抓拍证据图
AUTO_TRACK_STOP_SNAPSHOT_ENABLED=true

# 转向命令发出后延迟此时间自动发 stop，防止过冲（ms，0=禁用）
AUTO_TRACK_YAW_PULSE_MS=0

# ==================== 宇树 B2 硬件 ====================
# 仅当 CONTROL_ADAPTER_TYPE=unitree_b2 时生效
# 连接 B2 的有线网卡名，必须是 192.168.123.x 网段那块口，不能写成 HM30 地面站通信口！
# 查询方法：ip addr show | grep "192.168.123" 
# Jetson Orin NX 内置网口通常是 eno1；OrangePi 通常是 enP3p49s0；纯 eth0 为缺省占位
UNITREE_NETWORK_IFACE=eno1

# 前进/后退速度（m/s），B2 支持 0~0.6
UNITREE_B2_VX=0.3

# 偏航转速（rad/s），B2 支持 0~0.8
UNITREE_B2_VYAW=0.5
