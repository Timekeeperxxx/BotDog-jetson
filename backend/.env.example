# BotDog 后端配置模板
# 复制此文件为 .env 并根据实际情况修改：
#   cp backend/.env.example backend/.env   (Linux/Mac)
#   copy backend\.env.example backend\.env  (Windows)

# ==================== 基础网络配置 ====================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ==================== MAVLink / 数据库 ====================
# 真实硬件：使用串口，例如 serial:/dev/ttyUSB0:57600 (Linux) 或 serial:COM3:57600 (Windows)
# 无硬件开发：保持 udp:127.0.0.1:14550，并将 MAVLINK_SOURCE 设置为 simulation
MAVLINK_ENDPOINT=udp:127.0.0.1:14550

# 数据库文件路径（SQLite，首次运行自动创建）
DATABASE_URL=sqlite+aiosqlite:///./data/botdog.db

# ==================== 安全配置 ====================
# 生产环境请修改为随机字符串
JWT_SECRET=please_change_me_to_a_random_string

# ==================== CORS 配置 ====================
# 开发阶段允许所有来源；生产环境请改为前端实际域名，例如：
# CORS_ALLOW_ORIGINS=["http://192.168.1.100:5174"]
CORS_ALLOW_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=false

# ==================== MAVLink 数据源选择 ====================
# mavlink   - 连接真实硬件（需要机器狗在线）
# simulation - 使用模拟数据（无需任何硬件，推荐初次体验使用）
MAVLINK_SOURCE=simulation

# ==================== 模拟数据 Worker 控制 ====================
# MAVLINK_SOURCE=simulation 时设置为 true，可生成随机遥测数据
SIMULATION_WORKER_ENABLED=true

# ==================== 心跳和遥测配置 ====================
HEARTBEAT_TIMEOUT=3.0
TELEMETRY_SAMPLING_HZ=2.0
TELEMETRY_BROADCAST_HZ=15.0

# ==================== AI 告警配置 ====================
THERMAL_THRESHOLD=80.0

# ==================== 旁路 AI 识别与抓拍 ====================
# 注意：AI_ENABLED=true 需要 yolov8n.pt 模型文件（~6MB）
# 模型下载：https://github.com/ultralytics/assets/releases/download/v8.2.0/yolov8n.pt
# 无需 AI 功能时请保持 AI_ENABLED=false
AI_ENABLED=false
AI_RTSP_URL=rtsp://127.0.0.1:8554/cam
AI_FRAME_WIDTH=1280
AI_FRAME_HEIGHT=720
AI_FPS=10
AI_PATROL_SKIP=5
AI_SUSPECT_SKIP=1
AI_STABLE_HITS=3
AI_RESET_MISSES=3
AI_COOLDOWN_SECONDS=5.0
AI_SIMULATE_DETECTION=false
AI_SIMULATE_PROB=0.02
AI_DEVICE=auto
AI_MODEL_PATH=yolov8n.pt
AI_CONFIDENCE_THRESHOLD=0.5
AI_TARGET_CLASSES=["person"]

# ==================== 控制服务 ====================
# simulated   - 无硬件控制仿真（开发/CI 阶段使用）
# mavlink     - 通过 MAVLink 控制真实机器狗（预留）
# unitree_b2  - 宇树 B2 真实硬件（通过 unitree_sdk2_python / CycloneDDS）
CONTROL_ADAPTER_TYPE=simulated
CONTROL_WATCHDOG_TIMEOUT_MS=500
CONTROL_CMD_RATE_LIMIT_MS=80

# ==================== 宇树 B2 专用配置 ====================
# 仅当 CONTROL_ADAPTER_TYPE=unitree_b2 时生效
# 依赖：pip install unitree_sdk2_python (cyclonedds==0.10.2)
# 网络：网线直连 B2（默认 IP 192.168.123.161）
UNITREE_NETWORK_IFACE=eth0
UNITREE_B2_VX=0.3
UNITREE_B2_VYAW=0.5
