# BotDog Frontend Environment Variables
# 方案 B：留空 VITE_API_BASE_URL 和 VITE_WHEP_URL，
# 代码运行时自动从 window.location 推算，无论从哪个 IP 访问均可。

# 后端 API 地址（留空=自动使用当前页面 origin，即 OrangePi IP:8000）
VITE_API_BASE_URL=

# MediaMTX WHEP 播放地址（留空=自动使用当前页面 hostname:8889）
VITE_WHEP_URL=

# 视频清晰度宽度（1920 => 1080p, 1280 => 720p）
VITE_STREAM_WIDTH=1280
