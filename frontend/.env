# BotDog Frontend Environment Variables

# 后端 API 地址（默认指向 192.168.144.30）
VITE_API_BASE_URL=http://127.0.0.1:8000


# WebSocket 地址（自动从 API 地址生成）
# 格式: ws://<host>:<port>

# MediaMTX WHEP 播放地址
VITE_WHEP_URL=http://192.168.144.30:8889/cam/whep

# 视频清晰度宽度（1920 => 1080p, 1280 => 720p）
VITE_STREAM_WIDTH=1920
